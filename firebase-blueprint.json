{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" },
        "displayName": { "type": "string" },
        "login": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "manager", "admin", "owner", "viewer"] },
        "branchId": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "login", "role", "createdAt"]
    },
    "CRMRequest": {
      "title": "CRM Request",
      "description": "Client requests or complaints",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientPhoto": { "type": "string" },
        "message": { "type": "string" },
        "classification": { "type": "string" },
        "status": { "type": "string", "enum": ["in_progress", "done"] },
        "managerId": { "type": "string" },
        "branchId": { "type": "string" },
        "deadlineAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "clientPhone", "message", "status", "branchId", "createdAt"]
    },
    "RequestAction": {
      "title": "Request Action",
      "description": "Actions taken on a specific request",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "instantFix": { "type": "string" },
        "resolution": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "resolution", "createdBy", "createdAt"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Audit trail of actions in the system",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/requests/{requestId}": {
      "schema": "CRMRequest",
      "description": "List of CRM requests"
    },
    "/requestActions/{actionId}": {
      "schema": "RequestAction",
      "description": "Actions carried out on requests"
    },
    "/logs/{logId}": {
      "schema": "SystemLog",
      "description": "Audit logs"
    }
  }
}
