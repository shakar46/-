{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" },
        "displayName": { "type": "string" },
        "login": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "manager", "admin", "owner", "head", "viewer"] },
        "branchId": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "login", "role", "createdAt"]
    },
    "CRMRequest": {
      "title": "CRM Request",
      "description": "Client requests or complaints with expanded fields",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientPhoto": { "type": "string" },
        "message": { "type": "string" },
        "classification": { "type": "string" },
        "classificationSection": { "type": "string" },
        "status": { "type": "string", "enum": ["in_progress", "done", "under_review"] },
        "managerId": { "type": "string" },
        "branchId": { "type": "string" },
        "branchName": { "type": "string" },
        "deadlineAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "dateReceived": { "type": "string", "format": "date-time" },
        "orderDate": { "type": "string" },
        "additionalComment": { "type": "string" },
        "productEmployee": { "type": "array", "items": { "type": "string" } },
        "orderCheck": { "type": "string" },
        "briefDescription": { "type": "string" },
        "source": { "type": "string" },
        "samplePhotoEvidence": { "type": "array", "items": { "type": "string" } },
        "extraPhoto": { "type": "array", "items": { "type": "string" } },
        "complaintTaker": { "type": "string" },
        "sipAudio": { "type": "string" },
        "responsibleForCorrection": { "type": "string" },
        "deadlineStatus": { "type": "string" },
        "instantCorrection": { "type": "string" },
        "finalResolution": { "type": "string" },
        "rootCauseAnalysis": { "type": "string" },
        "motivationStatus": { "type": "array", "items": { "type": "string" } },
        "correctiveActions": { "type": "string" },
        "significance": { "type": "string" },
        "confirmedClassification": { "type": "string" },
        "confirmedSection": { "type": "string" },
        "confirmedMotivationDept": { "type": "string" },
        "validityStatus": { "type": "string", "enum": ["обоснованный", "не обоснованный", "выявляется"] }
      },
      "required": ["clientName", "clientPhone", "message", "status", "branchId", "createdAt"]
    },
    "RequestAction": {
      "title": "Request Action",
      "description": "Actions taken on a specific request",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "instantFix": { "type": "string" },
        "resolution": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "resolution", "createdBy", "createdAt"]
    },
    "Dictionary": {
      "title": "Dictionary",
      "description": "System-wide dropdown values and groups",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "groups": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "items": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/requests/{requestId}": {
      "schema": "CRMRequest",
      "description": "List of CRM requests"
    },
    "/request_actions/{actionId}": {
      "schema": "RequestAction",
      "description": "Actions carried out on requests"
    },
    "/dictionaries/{dictId}": {
      "schema": "Dictionary",
      "description": "System dictionaries"
    }
  }
}
