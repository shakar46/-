rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (optional, linked on login)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - role: string (admin, operator)
    //   - createdAt: timestamp/string
    //
    // Collection: appeals
    // Fields:
    //   - client_name: string
    //   - client_phone: string
    //   - complaint_text: string
    //   - status: string
    //   ...
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "shakar0406@gmail.com";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSuperAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "admin");
    }

    function isOperator() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "operator";
    }

    function isStaff() {
      return isAdmin() || isOperator();
    }

    function isValidUser(data) {
      return data.email is string && 
             data.role in ["admin", "operator"] &&
             data.displayName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      // Allow users to read their own document (by UID or by email match)
      // Also allow reading documents that have a loginToken (for quick login lookup)
      allow read: if isStaff() || (isAuthenticated() && (
        request.auth.uid == userId || 
        resource.data.email == request.auth.token.email ||
        resource.data.loginToken != null
      ));
      
      // Allow super admin to create anything
      // Allow admins to create operators
      // Allow authenticated users to create their own document IF they match a pre-added email OR if they have a valid token
      allow create: if (isAdmin() && isValidUser(request.resource.data) && (isSuperAdmin() || request.resource.data.role == "operator")) ||
                    (isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && 
                     exists(/databases/$(database)/documents/users/$(request.auth.uid)) == false &&
                     (request.resource.data.email == request.auth.token.email || request.resource.data.loginToken == null));
      
      // Allow users to update their own document (e.g. lastLogin, claiming token)
      allow update: if (isAdmin() && isValidUser(request.resource.data) && (resource.data.email != "shakar0406@gmail.com") && (isSuperAdmin() || request.resource.data.role == "operator")) ||
                    (isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && 
                     (request.resource.data.email == resource.data.email || resource.data.loginToken != null) &&
                     request.resource.data.role == resource.data.role);
      
      // Allow super admin to delete anything
      // Allow admins to delete non-super-admins
      // Allow a user to delete a pre-added document if it matches their email or they are claiming it via token
      allow delete: if (isAdmin() && resource.data.email != "shakar0406@gmail.com") ||
                    (isAuthenticated() && (
                      (resource.data.email == request.auth.token.email && resource.data.uid == null) ||
                      (resource.data.loginToken != null && resource.data.uid == null)
                    ));
    }

    // Appeals Collection
    match /appeals/{appealId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Audit Logs (Appeal specific)
    match /audit_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    // Global Audit History (Login/Logout/Actions)
    match /audit_history/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Scripts
    match /scripts/{scriptId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Public Form Access (if needed)
    // The prompt says "Доступ к платформе ограничен", but there is a PublicForm.
    // Usually public forms write to a specific collection or have specific rules.
    // If PublicForm writes to 'appeals', we might need to allow unauthenticated create.
    // However, the prompt says "Любой пользователь, не добавленный в систему администратором, не может войти в платформу."
    // This usually refers to the CRM interface.
    // Let's check if PublicForm is used by external clients.
    // In App.tsx, /form is excluded from the login check.
  }
}
