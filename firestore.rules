rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Master Gate (Helpers) ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // Mandate email_verified == true OR internal domain OR common trusted providers.
      // Or just allow authenticated users if they have a real email.
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        (request.auth.token.email != null && (
          request.auth.token.email.endsWith('@crm-internal.local') ||
          request.auth.token.email.endsWith('@gmail.com') ||
          request.auth.token.email.endsWith('@mail.ru') ||
          request.auth.token.email.endsWith('@yandex.ru')
        )) ||
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function getRole() {
      // Prioritize role from custom claims (token) for performance and reliability
      // Fallback to database lookup if token claim is missing
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'operator')
           : 'operator'); // Default to operator for registered users to avoid being locked out
    }

    function isAdmin() {
      return isSignedIn() && getRole() in ['admin', 'owner', 'head'];
    }

    function isManager() {
      return isSignedIn() && getRole() in ['manager', 'admin', 'owner', 'head'];
    }

    function isOperator() {
      return isSignedIn() && getRole() in ['operator', 'manager', 'admin', 'owner', 'head'];
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 2. Validation Blueprints ---

    function isValidRequest(data) {
      return (data.get('clientName', '') is string) && 
             (data.get('clientPhone', '') is string) &&
             (data.get('status', 'new') in ['new', 'in_progress', 'done', 'under_review', 'cancelled']) &&
             data.get('createdAt', null) != null;
    }

    function isValidAction(data) {
      return data.requestId is string && isValidId(data.requestId) &&
             data.resolution is string && data.resolution.size() <= 10000 &&
             data.createdBy == request.auth.uid &&
             data.createdAt != null;
    }

    function isValidUser(data) {
      return data.login is string && data.login.size() <= 100 &&
             data.displayName is string && data.displayName.size() <= 200 &&
             data.role in ['head', 'admin', 'operator', 'manager', 'viewer'];
    }

    // --- 3. Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        // Prevent users from changing their own role
        (request.auth.uid == userId && !isAdmin() && incoming().role == existing().role) ||
        isAdmin()
      ) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow get: if isSignedIn() && isValidId(requestId);
      allow list: if isSignedIn(); // Queries must filter by branch if manager
      
      allow create: if isSignedIn() && (
        incoming().createdBy == request.auth.uid || 
        incoming().createdBy == 'public' ||
        incoming().createdBy == 'system'
      ) && (
        incoming().keys().hasAll(['clientName', 'clientPhone', 'status', 'createdAt', 'createdBy'])
      );
      
      allow update: if isSignedIn() && isValidId(requestId) && isEmailVerified() && (
        // Terminal state lock: can't update if done, unless admin
        (existing().status != 'done' || isAdmin())
      ) && (
        // Action: Operator/Manager update
        (isOperator() && (
           // Identity Integrity: cannot change who created it or when
           incoming().get('createdBy', '') == existing().get('createdBy', '') &&
           incoming().get('createdAt', null) == existing().get('createdAt', null) &&
           // Whitelist allowed fields for update
           incoming().diff(existing()).affectedKeys().hasOnly([
             'clientName', 'clientPhone', 'message', 'classification', 'classificationSection', 
             'additionalComment', 'productEmployee', 'sipAudio', 'clientPhotos', 'clientPhoto',
             'orderDate', 'orderCheck', 'source', 'significance', 'branchId', 'branchName', 
             'dateReceived', 'updatedAt', 'rootCauseAnalysis', 'motivationDept', 'validityStatus', 
             'correctiveActions', 'classificationConfirmed', 'responsibleForCorrection', 
             'deadlineStatus', 'finalResolution', 'instantCorrection', 'managerId', 'status',
             'guestNumber', 'complaintTaker', 'deadlineAt', 'completedAt', 'viewedBy', 'viewedAt',
             'briefDescription', 'samplePhotoEvidence', 'extraPhoto', 'analyticsPhotos', 
             'poisoningDetails', 'isPoisoning', 'finalComment'
           ])
        )) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /request_actions/{actionId} {
      allow get: if isSignedIn() && isValidId(actionId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidAction(incoming()) && (
        exists(/databases/$(database)/documents/requests/$(incoming().requestId))
      );
      allow update: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['resolution', 'updatedAt'])
      ));
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && (
        isOperator() || (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    match /complaint_logs/{logId} {
      allow read: if isOperator();
      allow write: if isAdmin();
    }

    match /dictionaries/{dictId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /scripts/{scriptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /learning_base/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

