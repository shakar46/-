rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Master Gate (Helpers) ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // The instruction says MUST mandate email_verified == true for write operations.
      // We also check it for sensitive reads.
      return request.auth.token.email_verified == true || request.auth.token.email.endsWith('@crm-internal.local');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'viewer';
    }

    function isAdmin() {
      return isSignedIn() && getRole() in ['admin', 'owner', 'head'];
    }

    function isManager() {
      return isSignedIn() && getRole() in ['manager', 'admin', 'owner', 'head'];
    }

    function isOperator() {
      return isSignedIn() && getRole() in ['operator', 'manager', 'admin', 'owner', 'head'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 2. Validation Blueprints ---

    function isValidRequest(data) {
      return data.clientName is string && data.clientName.size() <= 100 &&
             data.clientPhone is string && data.clientPhone.size() <= 20 &&
             data.status in ['new', 'in_progress', 'done', 'under_review', 'cancelled'] &&
             data.branchId is string &&
             data.createdAt != null;
    }

    function isValidAction(data) {
      return data.requestId is string &&
             data.resolution is string && data.resolution.size() <= 5000 &&
             data.createdBy == request.auth.uid &&
             data.createdAt != null;
    }

    function isValidDictionary(data) {
      return data.name is string && data.name.size() <= 100;
    }

    // --- 3. Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow get: if isSignedIn() && isValidId(requestId);
      allow list: if isSignedIn(); // We should ideally filter by branch for managers, but for now allow list
      
      allow create: if isSignedIn() && isEmailVerified() && isValidRequest(incoming());
      
      allow update: if isSignedIn() && isEmailVerified() && (
        // Managers can update most fields
        isManager() || 
        // Operators can fill info
        isOperator()
      );
      
      allow delete: if isAdmin();
    }

    match /request_actions/{actionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidAction(incoming());
      allow update: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      // Users can see their own logs, Operators/Managers/Admins can see all
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isOperator());
      // Log creation via logger utility
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    match /complaint_logs/{logId} {
      allow read: if isOperator();
      allow write: if isAdmin();
    }

    match /dictionaries/{dictId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /scripts/{scriptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /learning_base/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
