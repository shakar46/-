rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() in ['admin', 'owner'];
    }

    function isOwner() {
      return isSignedIn() && getRole() == 'owner';
    }

    function isManager() {
      return isSignedIn() && getRole() == 'manager';
    }

    function isOperator() {
      return isSignedIn() && getRole() == 'operator';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'nickname', 'displayName', 'login', 'role', 'createdAt']) &&
             data.keys().size() >= 6 && data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.role in ['operator', 'manager', 'admin', 'owner', 'viewer'] &&
             data.login is string && data.login.size() <= 50 &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['clientName', 'clientPhone', 'message', 'status', 'branchId', 'createdAt']) &&
             data.keys().size() >= 6 && data.keys().size() <= 12 &&
             data.clientName is string && data.clientName.size() <= 100 &&
             data.clientPhone is string && data.clientPhone.size() <= 20 &&
             data.status in ['in_progress', 'done'] &&
             data.branchId is string;
    }

    function isValidAction(data) {
      return data.keys().hasAll(['requestId', 'resolution', 'createdBy', 'createdAt']) &&
             data.keys().size() >= 4 && data.keys().size() <= 6 &&
             data.createdBy == request.auth.uid &&
             data.resolution is string && data.resolution.size() <= 1000;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'action', 'createdAt']) &&
             data.keys().size() >= 3 && data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.action is string && data.action.size() <= 500;
    }

    // --- Collections ---

    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via API (Express routes)
    }

    match /request_actions/{actionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
