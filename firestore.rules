rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // 0. Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getSession() {
      return get(/databases/$(database)/documents/session_uids/$(request.auth.uid)).data;
    }

    function hasSession() {
      return isSignedIn() && exists(/databases/$(database)/documents/session_uids/$(request.auth.uid));
    }

    function isHead() {
      return hasSession() && (getSession().role == "head" || getSession().login == "shakar46");
    }

    function isAdmin() {
      return isHead() || (hasSession() && getSession().role == "admin");
    }

    function isStaff() {
      return isAdmin() || (hasSession() && getSession().role in ["operator", "manager"]);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.login is string && data.login.size() <= 100 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ["head", "admin", "operator", "manager"];
    }

    function isValidAppeal(data) {
      return data.client_name is string && data.client_name.size() <= 100 &&
             data.client_phone is string && data.client_phone.size() <= 20 &&
             data.complaint_text is string && data.complaint_text.size() <= 5000;
    }

    function isValidScript(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.category is string && data.category.size() <= 100;
    }

    function isValidLearningItem(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.category is string && data.category.size() <= 100 &&
             data.author is string && data.author.size() <= 100;
    }

    function isValidComplaintLog(data) {
      return data.appeal_id is string && data.appeal_id.size() <= 128 &&
             data.manager_id is string && data.manager_id.size() <= 128 &&
             data.timestamp is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      allow get: if true; // Needed for login check
      allow list: if isAdmin();
      
      allow create: if (isAdmin() && isValidUser(incoming()) && (incoming().role != 'head' || isHead())) ||
                    (isSignedIn() && isValidUser(incoming())); 
      
      allow update: if (isAdmin() && isValidUser(incoming()) && (incoming().role != 'head' || isHead()) && existing().login != "shakar46") ||
                    (hasSession() && getSession().login == existing().login);
      
      allow delete: if isAdmin() && existing().login != "shakar46";
    }

    match /session_uids/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
    }

    // Appeals Collection
    match /appeals/{appealId} {
      allow get: if isStaff() && isValidId(appealId);
      allow list: if isStaff();
      allow create: if (isStaff() || !isSignedIn()) && isValidAppeal(incoming());
      allow update: if isStaff() && isValidAppeal(incoming());
      allow delete: if isAdmin();
    }

    // Scripts
    match /scripts/{scriptId} {
      allow get: if isStaff() && isValidId(scriptId);
      allow list: if isStaff();
      allow create: if isAdmin() && isValidScript(incoming());
      allow update: if isAdmin() && isValidScript(incoming());
      allow delete: if isAdmin();
    }

    // Learning Base
    match /learning_base/{itemId} {
      allow get: if isStaff() && isValidId(itemId);
      allow list: if isStaff();
      allow create: if isStaff() && isValidLearningItem(incoming()) && 
                    incoming().created_by == request.auth.uid;
      allow update: if ((isAdmin() && incoming().created_by == existing().created_by) || (isStaff() && existing().created_by == request.auth.uid)) && 
                    isValidLearningItem(incoming()) &&
                    incoming().created_by == existing().created_by;
      allow delete: if isAdmin() || (isStaff() && existing().created_by == request.auth.uid);
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow list: if isStaff();
      allow get: if isStaff() && isValidId(logId);
      allow create: if true; // Allowed for public form logging
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Standard Appeals (Internal reference)
    match /standard_appeals/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Complaint Logs
    match /complaint_logs/{logId} {
      allow list: if isStaff();
      allow get: if isStaff() && isValidId(logId);
      allow create: if isStaff() && isValidComplaintLog(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
